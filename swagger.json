{
  "openapi": "3.0.0",
  "info": {
    "title": "Alumni Influencer API",
    "version": "1.0.0",
    "description": "API documentation for the Phantasmagoria Alumni AR Platform"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new alumni user",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "student1@eastminster.ac.uk"
                  },
                  "password": {
                    "type": "string",
                    "example": "MySecurePassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration successful"
          },
          "400": {
            "description": "Invalid input or email already registered"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Log in an alumni user",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "student1@eastminster.ac.uk"
                  },
                  "password": {
                    "type": "string",
                    "example": "MySecurePassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, returns JWT token"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "403": {
            "description": "Email not verified"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Log out an alumni user",
        "description": "Instructs the client application to discard the JWT token. (Stateless API)",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Successfully logged out message"
          }
        }
      }
    },
    "/api/profile": {
      "get": {
        "summary": "Get the logged-in user's profile",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Profile data retrieved successfully"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid token"
          }
        }
      },
      "post": {
        "summary": "Create or update user profile (with image upload)",
        "tags": [
          "Profile"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "bio": {
                    "type": "string"
                  },
                  "profile_image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile saved successfully"
          }
        }
      }
    },
    "/api/bids/my-bids": {
      "get": {
        "summary": "View your personal bidding history and current bid status",
        "tags": [
          "Bidding System"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Returns an array of the user's past and active bids"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid token"
          },
          "500": {
            "description": "Server error fetching bid history"
          }
        }
      }
    },
    "/api/bids/place": {
      "post": {
        "summary": "Place or increase a bid for tomorrow's Alumni of the Day",
        "tags": [
          "Bidding System"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bid_amount": {
                    "type": "number",
                    "example": 50.00
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bid placed or increased successfully"
          },
          "400": {
            "description": "Bid must be higher than current bid"
          },
          "403": {
            "description": "Monthly win limit reached"
          }
        }
      }
    },
    "/api/bids/alumnus-of-the-day": {
      "get": {
        "summary": "Get today's winning Alumni Influencer",
        "tags": [
          "Bidding System (Public API)"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the profile of today's winner"
          },
          "401": {
            "description": "Missing or invalid API Key"
          }
        }
      }
    },
    "/api/developer/keys/generate": {
      "post": {
        "summary": "Generate a new API key for a developer app",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "app_name": {
                    "type": "string",
                    "example": "AR Client App"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "API Key generated successfully"
          }
        }
      }
    },
    "/api/developer/keys/stats": {
      "get": {
        "summary": "View usage statistics for all your API keys",
        "tags": [
          "Developer API Keys"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Returns usage counts and last access timestamps"
          }
        }
      }
    }
  }
}